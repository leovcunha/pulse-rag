# API keys required for the Sub-2-Second Web-Scale RAG System

# Search API Key (Tavily is default)
TAVILY_API_KEY=your_tavily_api_key_here

# Rerank API Key (Cohere)
COHERE_API_KEY=your_cohere_api_key_here

# LLM Providers (Groq is primary, OpenRouter is fallback)
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
